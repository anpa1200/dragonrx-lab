# Vagrant runtime state
.vagrant/

# Sliver C2 runtime data (generated by sliver-server daemon)
# Never commit operator keys, implant DB, or compiled toolchains
c2/configs/*
!c2/configs/.gitkeep
c2/loot/*
!c2/loot/.gitkeep

# Attacker volume mounts (runtime tools and exfiltrated data)
attacker/tools/*
!attacker/tools/.gitkeep
attacker/loot/*
!attacker/loot/.gitkeep

# Compiled Java exploit classes
jndi/payloads/*.class
jndi/payloads/*.jar

# Ansible retry files
ansible/*.retry
ansible/**/*.retry

# Python cache
__pycache__/
*.pyc

# Editor
.idea/
.vscode/
*.swp
