<Sysmon schemaversion="4.82">
  <EventFiltering>

    <RuleGroup name="ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="contains">cmd.exe</Image>
        <Image condition="contains">powershell.exe</Image>
        <Image condition="contains">rundll32.exe</Image>
        <Image condition="contains">certutil.exe</Image>
        <Image condition="contains">wmic.exe</Image>
        <Image condition="contains">mshta.exe</Image>
        <Image condition="contains">vssadmin.exe</Image>
        <Image condition="contains">diskshadow.exe</Image>
        <Image condition="contains">nltest.exe</Image>
        <Image condition="contains">net.exe</Image>
        <ParentImage condition="contains">java.exe</ParentImage>
        <CommandLine condition="contains">comsvcs</CommandLine>
        <CommandLine condition="contains">MiniDump</CommandLine>
        <CommandLine condition="contains">sekurlsa</CommandLine>
        <CommandLine condition="contains">delete shadows</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="NetworkConnect" groupRelation="or">
      <NetworkConnect onmatch="include">
        <Image condition="contains">java.exe</Image>
        <Image condition="contains">powershell.exe</Image>
        <Image condition="contains">rundll32.exe</Image>
        <DestinationPort condition="is">443</DestinationPort>
        <DestinationPort condition="is">4444</DestinationPort>
      </NetworkConnect>
    </RuleGroup>

    <!-- groupRelation="and": ALL conditions must match.                                     -->
    <!-- "or" here would fire on EVERY unsigned DLL anywhere on the system — massive noise. -->
    <RuleGroup name="ImageLoad" groupRelation="and">
      <ImageLoad onmatch="include">
        <ImageLoaded condition="contains">jvm.dll</ImageLoaded>
        <ImageLoaded condition="begins with" not="true">C:\Windows\</ImageLoaded>
        <ImageLoaded condition="begins with" not="true">C:\Program Files\</ImageLoaded>
        <Signed condition="is">false</Signed>
      </ImageLoad>
    </RuleGroup>

    <RuleGroup name="ProcessAccess" groupRelation="or">
      <ProcessAccess onmatch="include">
        <TargetImage condition="ends with">lsass.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>

    <RuleGroup name="FileCreate" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="contains">\Tasks\</TargetFilename>
        <TargetFilename condition="ends with">.jsp</TargetFilename>
        <TargetFilename condition="ends with">.aspx</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <RuleGroup name="DnsQuery" groupRelation="or">
      <DnsQuery onmatch="include">
        <QueryName condition="contains">oracle-cdn</QueryName>
        <QueryName condition="contains">attacker-infra</QueryName>
        <QueryName condition="contains">tunnel</QueryName>
      </DnsQuery>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
